# Port du serveur
PORT=3000

# Secret JWT (changez en production !)
JWT_SECRET=changez-moi-par-une-valeur-aleatoire-tres-longue

# Admin initial (utilisé uniquement pour npm run init-admin)
ADMIN_USERNAME=sofiane
ADMIN_PASSWORD=changez-ce-mot-de-passe

# Date prévue de naissance (ISO 8601)
BIRTH_DATE=2026-08-07T00:00:00

# Noms des parents (affichés sur le site)
PARENT_1=Sofiane
PARENT_2=Katia

# URL publique (utilisée pour les liens dans les emails, etc.)
PUBLIC_URL=http://localhost:3000

# NODE_ENV (production désactive certaines infos de debug)
NODE_ENV=development
