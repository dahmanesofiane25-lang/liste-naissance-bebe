# =====================================================================
# Nginx reverse proxy pour la liste de naissance
# À placer dans /etc/nginx/sites-available/liste-naissance
# Puis :
#   sudo ln -s /etc/nginx/sites-available/liste-naissance /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Pour le HTTPS, utilisez Certbot :
#   sudo certbot --nginx -d votre-domaine.fr
# =====================================================================

server {
    listen 80;
    listen [::]:80;
    server_name votre-domaine.fr www.votre-domaine.fr;

    # Taille max du body (pour les uploads futurs)
    client_max_body_size 5M;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 1024;

    # Sécurité de base
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Logs
    access_log /var/log/nginx/liste-naissance.access.log;
    error_log  /var/log/nginx/liste-naissance.error.log;

    # Cache pour les assets statiques servis par Node
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf)$ {
        proxy_pass http://127.0.0.1:3000;
        proxy_cache_valid 200 7d;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # Reverse proxy vers Node
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection        "";
        proxy_connect_timeout 30s;
        proxy_read_timeout    30s;
    }
}

# Bloc HTTPS généré automatiquement par Certbot après la commande :
#   sudo certbot --nginx -d votre-domaine.fr
